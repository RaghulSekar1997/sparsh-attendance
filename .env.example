# Copy this file to .env and fill in your values
# NEVER commit .env to version control

WEBSITE_URL=https://pro.dolynkcloud.com/#/login
RECORDS_URL=https://pro.dolynkcloud.com/#/access/record/list

USERNAME=your_email@example.com
PASSWORD=your_password_here

# Where to save downloaded CSV files
DOWNLOAD_DIR=~/Documents/attendance_downloads

# Set to false to watch the browser (useful for debugging)
HEADLESS=true

# Retry attempts for login / navigation failures
MAX_RETRIES=3

# Per-operation timeout in milliseconds (30 000 = 30 s)
TIMEOUT=30000
